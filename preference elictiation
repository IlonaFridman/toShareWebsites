
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lung Cancer Screening — Preference Elicitation</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
  :root{
    --teal:#0d6a86;--teal-dark:#0a5066;--blue:#2b8cb3;--blue-light:#d6eef7;
    --blue-lighter:#eef8fc;--ink:#1f2937;--muted:#5b6b78;
    --bubble-bot:#eef8fc;--bubble-user:#0d6a86;
    --shadow:0 2px 10px rgba(0,0,0,.08);
  }
  *{box-sizing:border-box}
  body{margin:0;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    background:linear-gradient(180deg,#f4fbfe 0%,#eaf5fb 100%);color:var(--ink);min-height:100vh;}
  .wrap{max-width:760px;margin:0 auto;padding:0 16px 40px;}
  header{text-align:center;padding:26px 16px 14px;}
  header h1{margin:0;font-size:1.45rem;color:var(--teal);}
  header p{margin:6px 0 0;color:var(--muted);font-size:.95rem;}
  .progress{height:8px;background:#dceaf2;border-radius:6px;overflow:hidden;margin:16px 0 8px;}
  .progress > div{height:100%;width:0;background:var(--blue);transition:width .35s ease;}
  .progress-label{font-size:.8rem;color:var(--muted);text-align:right;margin-bottom:10px;}
  .chat{background:#fff;border-radius:16px;box-shadow:var(--shadow);padding:18px;min-height:340px;
    display:flex;flex-direction:column;gap:14px;}
  .row{display:flex;gap:10px;align-items:flex-end;animation:rise .3s ease;}
  .row.user{flex-direction:row-reverse;}
  @keyframes rise{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
  .avatar{width:34px;height:34px;border-radius:50%;flex:0 0 34px;display:flex;align-items:center;
    justify-content:center;font-size:.78rem;font-weight:700;color:#fff;}
  .avatar.bot{background:var(--blue);}
  .avatar.you{background:var(--teal);font-size:.7rem;}
  .bubble{max-width:78%;padding:12px 14px;border-radius:14px;line-height:1.45;font-size:.97rem;}
  .bubble.bot{background:var(--bubble-bot);border-bottom-left-radius:4px;}
  .bubble.user{background:var(--bubble-user);color:#fff;border-bottom-right-radius:4px;}
  .scale-hint{font-size:.82rem;color:var(--muted);margin-top:6px;}
  .scale-row{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;}
  .opt{width:84px;min-height:74px;border-radius:12px;border:2px solid var(--blue);background:#fff;
    color:var(--teal);cursor:pointer;transition:.15s;display:flex;flex-direction:column;
    align-items:center;justify-content:center;gap:3px;padding:6px 4px;}
  .opt .num{font-size:1.15rem;font-weight:800;}
  .opt .lab{font-size:.62rem;line-height:1.1;color:var(--muted);font-weight:600;}
  .opt:hover{background:var(--blue);color:#fff;transform:translateY(-2px);}
  .opt:hover .lab{color:#fff;}
  .controls{display:flex;justify-content:space-between;margin-top:14px;}
  button.ghost{background:none;border:none;color:var(--blue);cursor:pointer;font-size:.9rem;padding:6px 10px;border-radius:8px;}
  button.ghost:hover{background:var(--blue-lighter);}
  button.ghost:disabled{color:#b9c6cf;cursor:default;background:none;}
  /* result */
  .result-card{border-radius:14px;padding:22px;margin-top:6px;border:1px solid #e3edf3;background:#fff;}
  .result-lead{color:var(--blue);font-weight:800;font-size:1.15rem;margin:0 0 6px;}
  .result-body{margin:0 0 18px;line-height:1.5;}
  .bar-wrap{position:relative;margin:34px 0 6px;}
  .person{position:absolute;top:-30px;width:26px;text-align:center;transform:translateX(-50%);transition:left .5s ease;z-index:3;}
  .person svg{width:22px;height:30px;}
  .bar{display:flex;height:58px;position:relative;}
  .seg{flex:1;display:flex;align-items:center;justify-content:center;text-align:center;color:#fff;
    font-size:.72rem;font-weight:700;padding:4px 8px;line-height:1.25;opacity:.5;transition:.3s;}
  .seg.left{background:var(--teal-dark);}
  .seg.mid{background:var(--blue);}
  .seg.right{background:var(--teal-dark);}
  .seg.active{opacity:1;box-shadow:inset 0 0 0 3px rgba(255,255,255,.5);}
  .arrow-l,.arrow-r{width:0;height:0;border-top:29px solid transparent;border-bottom:29px solid transparent;}
  .arrow-l{border-right:26px solid var(--teal-dark);}
  .arrow-r{border-left:26px solid var(--teal-dark);}
  .actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:22px;}
  .btn{border:none;padding:11px 20px;border-radius:10px;font-size:.92rem;cursor:pointer;font-weight:600;}
  .btn-primary{background:var(--teal);color:#fff;}
  .btn-primary:hover{background:var(--blue);}
  .btn-primary:disabled{opacity:.6;cursor:default;}
  .btn-out{background:#fff;color:var(--teal);border:2px solid var(--teal);}
  .btn-out:hover{background:var(--blue-lighter);}
  .disclaimer{font-size:.78rem;color:var(--muted);text-align:center;margin-top:18px;line-height:1.5;}
  /* offscreen pdf report */
  #report{position:absolute;left:-99999px;top:0;width:760px;background:#fff;padding:30px;}
  #report .r-title{font-size:1.3rem;color:var(--teal);font-weight:800;margin:0;}
  #report .r-date{color:var(--muted);font-size:.85rem;margin:4px 0 18px;}
  #report .qa{margin:0 0 14px;padding-bottom:12px;border-bottom:1px solid #eef2f5;}
  #report .qa .q{font-weight:600;margin:0 0 6px;line-height:1.4;}
  #report .qa .a{display:inline-block;background:var(--bubble-user);color:#fff;padding:6px 12px;border-radius:12px;font-size:.9rem;}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1>Lung Cancer Screening — Let's talk it through</h1>
    <p>Ten short questions to understand what matters to you. There are no right or wrong answers.</p>
  </header>
  <div class="progress"><div id="bar"></div></div>
  <div class="progress-label" id="plabel">Getting started…</div>
  <div class="chat" id="chat"></div>
  <div class="controls">
    <button class="ghost" id="back" disabled>← Back</button>
    <button class="ghost" id="restartTop" style="visibility:hidden">Start over</button>
  </div>
  <p class="disclaimer">This tool helps organize your thoughts for a conversation with your healthcare provider.
    It is not medical advice and does not replace a clinical decision.</p>
</div>
<div id="report"></div>

<script>
// type: 'benefit' = straightforward (score as-is); 'concern' = reverse-scored (6 - raw)
const QUESTIONS = [
  {type:'benefit', t:"How important to you is this benefit of lung cancer screening: the risk of dying from lung cancer decreases from 21 out of 1000 to 18 out of 1000 people?"},
  {type:'benefit', t:"How important is reducing your chance of dying from lung cancer?"},
  {type:'benefit', t:"How important is knowing as early as possible if lung cancer is present?"},
  {type:'benefit', t:"How much would you regret NOT being screened if lung cancer were later found?"},
  {type:'benefit', t:"“Getting lung cancer screening will lower my worry about lung cancer.” How much does this apply to you?"},
  {type:'concern', t:"How concerned are you about having a test that shows abnormal findings, while additional checkups confirm it to be benign? (a false alarm)"},
  {type:'concern', t:"How concerned are you about the risk associated with radiation exposure?"},
  {type:'concern', t:"Screening can sometimes find a cancer that would never have caused problems in your lifetime, leading to extra tests or treatment that may not have been needed. How concerned are you about this?"},
  {type:'concern', t:"Getting screening may take time and travel, such as going to an appointment or arranging transportation. How worried are you about this?"},
  {type:'concern', t:"How concerned are you about the stress and anxiety that lung cancer screening may cause for you and your family?"}
];
const LABELS=['','Not at all','A little','Moderately','Quite a bit','A great deal'];

const chat=document.getElementById('chat'),bar=document.getElementById('bar'),
  plabel=document.getElementById('plabel'),backBtn=document.getElementById('back'),
  restartTop=document.getElementById('restartTop');
let answers=[]; let idx=0; let startedAt=new Date();

function rowBot(html){const r=document.createElement('div');r.className='row bot';
  r.innerHTML='<div class="avatar bot">Dr</div><div class="bubble bot">'+html+'</div>';chat.appendChild(r);return r;}
function rowUser(text){const r=document.createElement('div');r.className='row user';
  r.innerHTML='<div class="avatar you">You</div><div class="bubble user">'+text+'</div>';chat.appendChild(r);}
function scrollDown(){chat.scrollTop=chat.scrollHeight;window.scrollTo(0,document.body.scrollHeight);}
function updateProgress(){bar.style.width=Math.round(idx/QUESTIONS.length*100)+'%';
  plabel.textContent=idx<QUESTIONS.length?('Question '+(idx+1)+' of '+QUESTIONS.length):'Complete';}
function clearScale(){document.querySelectorAll('.scale-block').forEach(e=>e.remove());}

function askCurrent(){
  updateProgress();
  backBtn.disabled=idx===0; restartTop.style.visibility=idx>0?'visible':'hidden';
  const q=QUESTIONS[idx];
  rowBot(q.t+'<div class="scale-hint">Tap a number from 1 to 5.</div>');
  const block=document.createElement('div');block.className='scale-block';block.style.marginTop='6px';
  let o='<div class="scale-row">';
  for(let n=1;n<=5;n++)o+='<button class="opt" data-n="'+n+'"><span class="num">'+n+'</span><span class="lab">'+LABELS[n]+'</span></button>';
  o+='</div>';
  block.innerHTML=o;chat.appendChild(block);
  block.querySelectorAll('.opt').forEach(b=>b.onclick=()=>choose(parseInt(b.dataset.n,10),q));
  scrollDown();
}
function choose(n,q){
  clearScale();
  answers[idx]={raw:n, type:q.type, q:q.t};
  rowUser(n+' — '+LABELS[n]);
  idx++; scrollDown();
  if(idx<QUESTIONS.length) setTimeout(askCurrent,350); else setTimeout(showResult,450);
}
backBtn.onclick=()=>{if(idx===0)return;clearScale();
  for(let k=0;k<3;k++){const r=[...chat.querySelectorAll('.row')];if(r.length)r[r.length-1].remove();}
  idx--;answers.pop();askCurrent();};
restartTop.onclick=restart;
function restart(){answers=[];idx=0;chat.innerHTML='';startedAt=new Date();
  rowBot("Thanks for being here. I'll ask 10 short questions about lung cancer screening and what matters to you the most and summarize your responses at the end. Here's the first one.");
  setTimeout(askCurrent,500);}

function computeAvg(){
  let sum=0;
  answers.forEach(a=>{sum += a.type==='concern' ? (6-a.raw) : a.raw;});
  return sum/answers.length;
}

function outcomeFor(avg){
  if(avg<2) return {active:'left',
    body:'This suggests you would prefer to think about screening later. That is a completely valid choice — it is not a "no forever," just a "not right now." You can revisit this decision anytime, and your doctor can check in with you again.'};
  if(avg<=4) return {active:'mid',
    body:'This means you should talk with a doctor before you decide whether or not to get a lung cancer screening. Your doctor may ask you more questions to help decide if screening is right for you.'};
  return {active:'right',
    body:'This means screening is your preference. Screening clearly lines up with what matters to you. The next step is to get connected with a screening center — your doctor can refer you, or you can find an accredited center using the trusted tools below.'};
}

function barHTML(avg,active){
  const pos=((avg-1)/4*100).toFixed(1);
  const personSVG='<svg viewBox="0 0 24 32"><circle cx="12" cy="6" r="5" fill="#111"/><rect x="7" y="12" width="10" height="14" rx="3" fill="#111"/><rect x="8" y="24" width="3" height="8" fill="#111"/><rect x="13" y="24" width="3" height="8" fill="#111"/></svg>';
  return '<div class="bar-wrap">'+
      '<div class="person" style="left:'+pos+'%">'+personSVG+'</div>'+
      '<div class="bar">'+
        '<div class="arrow-l"></div>'+
        '<div class="seg left'+(active==='left'?' active':'')+'">I prefer to think about screening later<br><small>(score below 2)</small></div>'+
        '<div class="seg mid'+(active==='mid'?' active':'')+'">MORE TIME &amp; information is needed<br><small>(score 2 to 4)</small></div>'+
        '<div class="seg right'+(active==='right'?' active':'')+'">SCREENING IS my preference<br><small>(score above 4)</small></div>'+
        '<div class="arrow-r"></div>'+
      '</div>'+
    '</div>';
}

function showResult(){
  updateProgress(); backBtn.disabled=true; restartTop.style.visibility='hidden';
  const avg=computeAvg(); const avgR=avg.toFixed(1);
  const oc=outcomeFor(avg);
  const lead='We averaged your scores on 10 questions, and your average score is: '+avgR;
  const resources = avg>4 ? '<ul style="margin:0 0 14px;padding-left:20px;line-height:1.5">'+
    '<li><a href="https://www.acr.org/Clinical-Resources/Clinical-Tools-and-Reference/Screening-Resources/lung-cancer-resources/locator-tool" target="_blank" rel="noopener">ACR Lung Cancer Screening Locator Tool</a></li>'+
    '<li><a href="https://www.lung.org/lung-health-diseases/lung-disease-lookup/lung-cancer/screening-resources" target="_blank" rel="noopener">American Lung Association — Screening Resources</a> (1-844-ALA-LUNG)</li>'+
    '<li><a href="https://lcfamerica.org/resources/screening-finder/" target="_blank" rel="noopener">Lung Cancer Foundation of America — Screening Finder</a></li></ul>' : '';

  const card=document.createElement('div');card.className='scale-block';
  card.innerHTML=
    '<div class="result-card">'+
      '<p class="result-lead">'+lead+'</p>'+
      '<p class="result-body">'+oc.body+'</p>'+resources+
      barHTML(avg,oc.active)+
      '<div class="actions">'+
        '<button class="btn btn-primary" id="dlBtn">⬇ Download PDF</button>'+
        '<button class="btn btn-out" onclick="restart()">Start over</button>'+
      '</div>'+
    '</div>';
  rowBot("Here's a summary of what you've told me:");
  chat.appendChild(card);
  document.getElementById('dlBtn').onclick=()=>downloadPDF(avg,avgR,lead,oc,resources);
  scrollDown();
}

function buildReport(avg,avgR,lead,oc,resources){
  const rep=document.getElementById('report');
  let qa='';
  answers.forEach((a,i)=>{
    qa+='<div class="qa"><p class="q">'+(i+1)+'. '+a.q+'</p>'+
        '<span class="a">'+a.raw+' — '+LABELS[a.raw]+'</span></div>';
  });
  rep.innerHTML=
    '<p class="r-title">Lung Cancer Screening — Your Preferences</p>'+
    '<p class="r-date">'+startedAt.toLocaleString()+'</p>'+
    '<div class="result-card" style="margin:0 0 22px">'+
      '<p class="result-lead">'+lead+'</p>'+
      '<p class="result-body">'+oc.body+'</p>'+resources+
      barHTML(avg,oc.active)+
    '</div>'+
    '<p style="font-weight:800;color:var(--teal);margin:0 0 10px">Your answers</p>'+
    qa+
    '<p style="font-size:.75rem;color:var(--muted);margin-top:16px;line-height:1.5">The five concern questions are reverse-scored '+
    '(6 − answer) so a higher average always means more favorable toward screening. '+
    'This tool supports shared decision-making with your provider and is not medical advice.</p>';
  return rep;
}

async function downloadPDF(avg,avgR,lead,oc,resources){
  const btn=document.getElementById('dlBtn');
  const old=btn.textContent; btn.textContent='Preparing PDF…'; btn.disabled=true;
  try{
    const rep=buildReport(avg,avgR,lead,oc,resources);
    const canvas=await html2canvas(rep,{scale:2,backgroundColor:'#ffffff'});
    const {jsPDF}=window.jspdf;
    const pdf=new jsPDF('p','mm','a4');
    const pw=pdf.internal.pageSize.getWidth();
    const ph=pdf.internal.pageSize.getHeight();
    const imgW=pw, imgH=canvas.height*pw/canvas.width;
    let left=imgH, pos=0;
    const img=canvas.toDataURL('image/png');
    pdf.addImage(img,'PNG',0,pos,imgW,imgH);
    left-=ph;
    while(left>0){ pos=left-imgH; pdf.addPage(); pdf.addImage(img,'PNG',0,pos,imgW,imgH); left-=ph; }
    pdf.save('lung-screening-preferences.pdf');
  }catch(e){ alert('Sorry, the PDF could not be generated: '+e.message); }
  finally{ btn.textContent=old; btn.disabled=false; }
}

restart();
</script>
</body>
</html>
